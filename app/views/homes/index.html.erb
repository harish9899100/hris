<% content_for :title, "Welcome" %>

<div class="min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 text-white px-4">
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-40"></div>

  <div class="relative text-center max-w-lg">
    <div class="w-16 h-16 rounded-2xl bg-brand-500 flex items-center justify-center mx-auto mb-6 shadow-2xl shadow-brand-500/40">
      <svg class="w-9 h-9 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
    </div>

    <h1 class="text-4xl font-extrabold mb-3 tracking-tight">HRIS Employee Portal</h1>
    <p class="text-slate-400 text-base mb-8 leading-relaxed">
      Manage your attendance, apply for leaves, and track your schedule — all in one place.
    </p>

    <div class="flex items-center justify-center gap-4">
      <%= link_to new_user_session_path,
            class: "inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-bold px-7 py-3.5 rounded-2xl transition-all shadow-xl shadow-brand-500/30 active:scale-95" do %>
        Sign In to Portal
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      <% end %>
    </div>

    <p class="text-slate-600 text-white mt-8">Human Resource Information System · v1.0</p>
  </div>
</div>