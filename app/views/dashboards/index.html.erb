<% content_for :title, "Dashboard" %>

<div class="mb-8 flex items-start justify-between flex-wrap gap-4">
  <div>
    <%
      hour = Time.current.hour
      greeting = hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening"
      emoji    = hour < 12 ? " " : hour < 17 ? " " : " "
    %>
    <h1 class="text-2xl font-bold text-slate-800"><%= greeting %>, <%= @employee.first_name %> <%= emoji %></h1>
    <p class="text-slate-400 text-sm mt-1 font-medium"><%= Date.current.strftime("%A, %B %-d, %Y") %></p>
  </div>
  <div class="mono text-right text-sm text-slate-400">
    <p class="text-xl font-bold text-slate-700" id="live-clock"></p>
    <p class="text-xs"><%= Time.current.time_zone %></p>
  </div>
</div>

<div class="relative bg-gradient-to-br from-brand-500 to-indigo-700 rounded-3xl p-6 mb-6 overflow-hidden shadow-xl shadow-brand-500/25">
  <div class="absolute -top-8 -right-8 w-40 h-40 rounded-full bg-white/5"></div>
  <div class="absolute -bottom-10 -left-4 w-32 h-32 rounded-full bg-white/5"></div>

  <div class="relative flex items-center justify-between flex-wrap gap-5">
    <div class="text-white">
      <p class="text-sm font-semibold text-black uppercase tracking-widest mb-1">Today's Attendance</p>
      <% if @attendance %>
        <div class="flex items-center gap-2 mb-2">
          <% if @attendance.checked_out? %>
            <span class="inline-flex items-center gap-1.5 bg-white/20 text-black text-xs font-semibold px-3 py-1 rounded-full">
               Day Completed · <%= @attendance.duration_formatted %>
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 bg-emerald-400/30 text-black text-xs font-semibold px-3 py-1 rounded-full">
              <span class="relative w-2 h-2">
                <span class="pulse-dot w-2 h-2 rounded-full bg-emerald-400 block relative"></span>
              </span>
              Currently Checked In
            </span>
          <% end %>
        </div>
        <div class="flex items-center gap-6 mt-3">
          <div>
            <p class="text-black text-xs mb-0.5">Check In</p>
            <p class="text-black text-black font-bold mono"><%= @attendance.check_in.strftime("%I:%M") %><span class="text-base font-normal text-black/70 ml-1"><%= @attendance.check_in.strftime("%p") %></span></p>
          </div>
          <% if @attendance.checked_out? %>
            <div class="w-px h-8 bg-white/20"></div>
            <div>
              <p class="text-black text-xs mb-0.5">Check Out</p>
              <p class="text-black text-black font-bold mono"><%= @attendance.check_out.strftime("%I:%M") %><span class="text-base font-normal text-black ml-1"><%= @attendance.check_out.strftime("%p") %></span></p>
            </div>
            <div class="w-px h-8 bg-white/20"></div>
            <div>
              <p class="text-black text-xs mb-0.5">Duration</p>
              <p class="text-black text-black font-bold mono"><%= @attendance.duration_formatted %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-black text-sm mt-1">You haven't checked in yet today.</p>
        <p class="text-black text-xs mt-0.5">Click "Check In" to start your workday.</p>
      <% end %>
    </div>

    <div class="flex flex-col gap-2.5">
      <% if @attendance.nil? %>
        <%= button_to check_in_attendance_records_path,
              method: :post,
              class: "inline-flex items-center justify-center gap-2 bg-white text-brand-600 font-bold text-sm px-6 py-3 rounded-2xl shadow-lg hover:bg-brand-50 transition-all active:scale-95 cursor-pointer" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
          </svg>
          Check In
        <% end %>
      <% elsif @attendance.checked_in? && !@attendance.checked_out? %>
        <%= button_to check_out_attendance_records_path,
              method: :post,
              class: "inline-flex items-center justify-center gap-2 bg-white/20 hover:bg-white/30 text-black font-bold text-sm px-6 py-3 rounded-2xl border border-white/30 transition-all active:scale-95 cursor-pointer" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Check Out
        <% end %>
      <% else %>
        <div class="bg-white/10 rounded-2xl px-5 py-3 text-black text-sm font-medium text-center">
           Workday Complete
        </div>
      <% end %>

      <%= link_to attendance_records_path,
            class: "inline-flex items-center justify-center gap-1.5 text-white/60 hover:text-black text-xs font-medium transition-colors" do %>
        View full history →
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%
    stats = [
      { label: "Present", value: @present_days, unit: "days", color: "emerald", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
      { label: "Absent",  value: @absent_days,  unit: "days", color: "red",     icon: "M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" },
      { label: "Late Arrivals", value: @late_days, unit: "days", color: "amber", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
      { label: "Leave Balance", value: @leave_balance[:annual], unit: "annual days left", color: "blue", icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" },
    ]
  %>
  <% stats.each do |s| %>
    <div class="card-hover bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
      <div class="flex items-start justify-between mb-3">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide"><%= s[:label] %></p>
        <div class="w-8 h-8 rounded-xl bg-<%= s[:color] %>-50 flex items-center justify-center">
          <svg class="w-4 h-4 text-<%= s[:color] %>-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="<%= s[:icon] %>"/>
          </svg>
        </div>
      </div>
      <p class="text-3xl font-extrabold text-<%= s[:color] %>-600"><%= s[:value] %></p>
      <p class="text-xs text-slate-400 mt-0.5"><%= s[:unit] %> · <%= Date.current.strftime("%B") %></p>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <div class="px-6 py-4 flex items-center justify-between border-b border-slate-50">
      <h2 class="font-bold text-slate-700 text-sm">Recent Attendance</h2>
      <%= link_to "View all →", attendance_records_path, class: "text-brand-500 text-xs font-semibold hover:underline" %>
    </div>
    <% if @recent_attendance.empty? %>
      <div class="px-6 py-10 text-center text-slate-300 text-sm">No records yet.</div>
    <% else %>
      <div class="divide-y divide-slate-50">
        <% @recent_attendance.each do |rec| %>
          <div class="px-6 py-3.5 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
            <div>
              <p class="text-sm font-semibold text-slate-700"><%= rec.date.strftime("%a, %b %-d") %></p>
              <p class="text-xs text-slate-400 mono mt-0.5">
                <%= rec.check_in&.strftime("%I:%M %p") || "—" %>
                <% if rec.check_out %> → <%= rec.check_out.strftime("%I:%M %p") %><% end %>
              </p>
            </div>
            <div class="flex items-center gap-2">
              <%= render "shared/attendance_badge", status: rec.status %>
              <% if rec.duration %>
                <span class="text-xs text-slate-300 mono"><%= rec.duration_formatted %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <div class="px-6 py-4 flex items-center justify-between border-b border-slate-50">
      <h2 class="font-bold text-black text-sm">Leave Requests</h2>
      <%= link_to "Apply leave →", new_leave_request_path, class: "text-brand-500 text-black font-semibold hover:underline" %>
    </div>
    <% if @recent_leaves.empty? %>
      <div class="px-6 py-10 text-center">
        <p class="text-slate-300 text-sm mb-2">No leave requests yet.</p>
        <%= link_to "Apply for your first leave →", new_leave_request_path, class: "text-brand-500 text-xs font-semibold hover:underline" %>
      </div>
    <% else %>
      <div class="divide-y divide-slate-50">
        <% @recent_leaves.each do |leave| %>
          <div class="px-6 py-3.5 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
            <div>
              <p class="text-sm font-semibold text-slate-700 capitalize"><%= leave.leave_type %> Leave</p>
              <p class="text-xs text-slate-400 mt-0.5">
                <%= leave.start_date.strftime("%b %-d") %> – <%= leave.end_date.strftime("%b %-d, %Y") %>
                <span class="text-slate-300">·</span> <%= leave.duration_days %> day<%= "s" if leave.duration_days > 1 %>
              </p>
            </div>
            <%= render "shared/leave_badge", status: leave.status %>
          </div>
        <% end %>
      </div>
      <div class="px-6 py-3 bg-slate-50/50 border-t border-slate-50">
        <%= link_to "View all leave requests", leave_requests_path, class: "text-xs text-slate-400 hover:text-brand-500 transition-colors font-medium" %>
      </div>
    <% end %>
  </div>

</div>

<div class="mt-6 bg-white rounded-2xl border border-slate-100 shadow-sm px-6 py-4 flex items-center gap-6 flex-wrap">
  <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mr-2">Leave Balance</p>
  <% [["Annual", @leave_balance[:annual], "brand"], ["Sick", @leave_balance[:sick], "emerald"], ["Casual", @leave_balance[:casual], "amber"]].each do |name, val, color| %>
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 rounded-full bg-<%= color %>-400"></div>
      <span class="text-sm font-semibold text-slate-700"><%= val %></span>
      <span class="text-xs text-slate-400"><%= name %></span>
    </div>
    <div class="w-px h-4 bg-slate-100 last:hidden"></div>
  <% end %>
  <%= link_to "Apply Leave", new_leave_request_path,
        class: "ml-auto text-xs font-bold bg-brand-500 text-black px-4 py-2 rounded-xl hover:bg-brand-600 transition-colors" %>
</div>

<script>
  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2,'0');
    const m = String(now.getMinutes()).padStart(2,'0');
    const s = String(now.getSeconds()).padStart(2,'0');
    const el = document.getElementById('live-clock');
    if (el) el.textContent = `${h}:${m}:${s}`;
  }
  updateClock();
  setInterval(updateClock, 1000);
</script>