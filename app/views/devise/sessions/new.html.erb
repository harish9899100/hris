<div class="min-h-screen bg-zinc-950 flex items-center justify-center p-6 relative overflow-hidden">

  <div class="absolute inset-0 overflow-hidden pointer-events-none" id="stars"></div>

  <div class="w-full max-w-md relative z-10">

    <div class="flex justify-center mb-10">
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-violet-600 rounded-2xl flex items-center justify-center">
          <span class="text-white text-3xl font-bold">H</span>
        </div>
        <span class="text-white text-4xl font-semibold tracking-tighter">Human-Resource-Information-System</span>
      </div>
    </div>

    <div class="bg-zinc-900/80 backdrop-blur-xl border border-zinc-700 rounded-3xl p-10 shadow-2xl">

      <div class="text-center mb-8">
        <h2 class="text-3xl font-semibold text-white">Welcome back</h2>
        <p class="text-zinc-400 mt-2">Sign in to your HR dashboard</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <div class="space-y-6">

          <div>
            <label class="block text-sm font-medium text-zinc-400 mb-2">Email Address</label><br>
            <%= f.email_field :email, 
                  autofocus: true, 
                  autocomplete: "email",
                  placeholder: "you@company.com",
                  class: "w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-3.5 text-white placeholder:text-zinc-500 focus:outline-none focus:border-indigo-500 transition-colors" %>
          </div>

          <div>
            <div class="flex justify-between items-center mb-2">
              <label class="block text-sm font-medium text-zinc-400">Password</label>
              <%= link_to "Forgot password?", new_user_password_path, class: "text-sm text-indigo-400 hover:text-indigo-300" %>
            </div>
            <%= f.password_field :password, 
                  autocomplete: "current-password",
                  placeholder: "••••••••",
                  class: "w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-3.5 text-white placeholder:text-zinc-500 focus:outline-none focus:border-indigo-500 transition-colors" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-3">
              <%= f.check_box :remember_me, class: "w-4 h-4 accent-indigo-500 bg-zinc-800 border-zinc-600" %>
              <label for="user_remember_me" class="text-sm text-zinc-400 cursor-pointer">Keep me signed in</label>
            </div>
          <% end %>

          <%= f.submit "Sign In",
                class: "bg-gradient-to-r from-indigo-500 to-violet-600 hover:from-indigo-600 hover:to-violet-700 text-white font-semibold py-4 rounded-2xl transition-all active:scale-95 mt-4 mx-auto block" %>

        </div>

      <% end %>

      <div class="text-center mt-8 text-sm">
        <span class="text-zinc-400">New to HRIS?</span>
        <%= link_to "Create an account", new_user_registration_path, class: "text-indigo-400 hover:text-indigo-300 ml-1 font-medium" %>
      </div>

    </div>

    <div class="text-center text-xs text-zinc-500 mt-8">
      Secure • Private • AI-Powered HR Platform © <%= Time.current.year %>
    </div>

  </div>
</div>

<script>
  function createStars() {
    const container = document.getElementById('stars');
    for (let i = 0; i < 80; i++) {
      const star = document.createElement('div');
      const size = Math.random() * 2.5 + 1;
      star.style.position = 'absolute';
      star.style.background = 'white';
      star.style.borderRadius = '50%';
      star.style.width = `${size}px`;
      star.style.height = `${size}px`;
      star.style.left = `${Math.random() * 100}%`;
      star.style.top = `${Math.random() * 100}%`;
      star.style.opacity = Math.random() * 0.6 + 0.3;
      star.style.animation = `twinkle ${3 + Math.random() * 4}s infinite ease-in-out`;
      star.style.animationDelay = `-${Math.random() * 5}s`;
      container.appendChild(star);
    }
  }

  createStars();
</script>

<style>
  @keyframes twinkle {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.9; }
  }
</style>