<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>
    <%= content_for?(:title) ? "#{yield(:title)} - HRIS" : "HRIS Employee Portal" %>
  </title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #f8fafc;
    }

    .nav-link {
      @apply block px-4 py-2 rounded-xl text-sm text-slate-600 hover:bg-slate-100;
    }

    .nav-link.active {
      background: #e0e7ff;
      color: #4338ca;
      font-weight: 600;
    }
  </style>
</head>

<body class="min-h-screen">

  <div class="flex min-h-screen">

    <% if user_signed_in? && current_employee %>

      <aside class="w-64 bg-white border-r p-4">

        <h1 class="text-xl font-bold mb-6">HRIS Portal</h1>

        <div class="mb-6 p-3 bg-slate-50 rounded-xl">
          <p class="font-semibold"><%= current_employee.full_name %></p>
          <p class="text-sm text-slate-500">
            ID: <%= current_employee.employee_id %>
          </p>
        </div>

        <nav class="space-y-2">
          <%= link_to "Dashboard", dashboards_path, class: "nav-link #{controller_name == 'dashboards' ? 'active' : ''}" %>
          <%= link_to "Attendance", attendance_records_path, class: "nav-link #{controller_name == 'attendance_records' ? 'active' : ''}" %>
          <%= link_to "Leave Requests", leave_requests_path, class: "nav-link #{controller_name == 'leave_requests' ? 'active' : ''}" %>
          <%= link_to "Payslips", payslips_path, class: "nav-link #{controller_name == 'payslips' ? 'active' : ''}" %>
          <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "nav-link text-red-500 bg-transparent border-0 cursor-pointer" %>
        </nav>

      </aside>

    <% end %>

    <main class="flex-1 p-8">

      <% if notice.present? %>
        <div class="mb-4 bg-green-100 text-green-700 px-4 py-2 rounded-xl">
          <%= notice %>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mb-4 bg-red-100 text-red-700 px-4 py-2 rounded-xl">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>

    </main>

  </div>

</body>
</html>