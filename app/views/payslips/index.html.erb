<div class="max-w-6xl mx-auto px-6 py-10">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">My Payslips</h1>
    <% if current_user&.hr_manager? || current_user&.dept_manager? %>
    <%# if super_admin? %> 
      <%= link_to "All Payslips (HR)", payslips_path, class: "text-blue-600 hover:underline" %>
    <% end %>
  </div>

  <% if @payslips.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @payslips.each do |payslip| %>
        <div class="bg-white dark:bg-gray-800 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden hover:shadow-md transition-shadow">
          <div class="p-6">
            <div class="flex justify-between items-start">
              <div>
                <div class="text-lg font-semibold text-gray-900 dark:text-white">
                  <%= Date::MONTHNAMES[payslip.month] %> <%= payslip.year %>
                </div>
                <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                  Payslip
                </div>
              </div>
              <div class="text-right">
                <div class="text-2xl font-bold text-emerald-600">
                  <%= number_to_currency(payslip.net) %>
                </div>
                <div class="text-xs text-gray-500">Net Pay</div>
              </div>
            </div>

            <div class="mt-6 space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">Gross Salary</span>
                <span class="font-medium"><%= number_to_currency(payslip.gross) %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">Deductions</span>
                <span class="font-medium text-red-600"><%= number_to_currency(payslip.deductions) %></span>
              </div>
            </div>
          </div>

          <div class="border-t border-gray-100 dark:border-gray-700 px-6 py-4 bg-gray-50 dark:bg-gray-900 flex gap-3">
            <%= link_to "View Details", payslip_path(payslip),
                  class: "flex-1 text-center py-3 text-sm font-medium border border-gray-300 dark:border-gray-600 rounded-2xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" %>

            <%= link_to "Download PDF", payslip_path(payslip, format: :pdf),
                  class: "flex-1 text-center py-3 text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white rounded-2xl transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20 bg-white dark:bg-gray-800 rounded-3xl">
      <p class="text-gray-500 dark:text-gray-400 text-lg">No payslips found yet.</p>
    </div>
  <% end %>

  <div class="mt-10 text-center">
    <%= link_to "← Back to Dashboard", dashboards_path, 
          class: "inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium" %>
  </div>
</div>