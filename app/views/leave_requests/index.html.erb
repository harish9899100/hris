<% content_for :title, "My Leaves" %>

<div class="mb-6 flex items-center justify-between flex-wrap gap-3">
  <div>
    <h1 class="text-xl font-bold text-slate-800">Leave Requests</h1>
    <p class="text-slate-400 text-sm mt-0.5">Apply and track your leave applications</p>
  </div>
  <%= link_to new_leave_request_path,
        class: "inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-black text-sm font-bold px-5 py-2.5 rounded-2xl transition-colors shadow-md shadow-brand-500/25 active:scale-95" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
    </svg>
    Apply Leave
  <% end %>
</div>

<div class="grid grid-cols-3 gap-4 mb-6">
  <% [
    ["Annual Leave",  @leave_balance[:annual],  "from-brand-500 to-indigo-600",  "21 days/year"],
    ["Sick Leave",    @leave_balance[:sick],     "from-emerald-500 to-teal-600",  "10 days/year"],
    ["Casual Leave",  @leave_balance[:casual],   "from-amber-500 to-orange-500",  "7 days/year"],
  ].each do |name, val, grad, subtitle| %>
    <div class="relative bg-gradient-to-br <%= grad %> rounded-2xl p-5 text-black overflow-hidden shadow-lg">
      <div class="absolute -top-4 -right-4 w-20 h-20 rounded-full bg-black/10"></div>
      <p class="text-xs font-bold text-black/70 uppercase tracking-widest mb-2"><%= name %></p>
      <p class="text-4xl font-extrabold mb-1"><%= val %></p>
      <p class="text-xs text-black/60">days remaining · <%= subtitle %></p>
    </div>
  <% end %>
</div>

<div class="flex items-center gap-1 bg-slate-100 rounded-2xl p-1 w-fit mb-5">
  <% [["All", nil], ["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"], ["Cancelled", "cancelled"]].each do |label, val| %>
    <%= link_to leave_requests_path(status: val),
          class: "px-4 py-2 rounded-xl text-sm font-semibold transition-all #{(params[:status].blank? && val.nil?) || params[:status] == val ? 'bg-white text-slate-800 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>
      <%= label %>
      <% if val == "pending" %>
        <% count = LeaveRequest.where(employee_id: current_employee.id, status: "pending").count %>
        <% if count > 0 %>
          <span class="ml-1 bg-amber-100 text-amber-700 text-[10px] font-bold px-1.5 rounded-full"><%= count %></span>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
  <% if @leave_requests.empty? %>
    <div class="py-20 text-center">
      <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <p class="text-slate-400 text-sm font-medium">No leave requests found.</p>
      <%= link_to "Apply for leave →", new_leave_request_path, class: "text-brand-500 text-sm font-bold hover:underline mt-1 inline-block" %>
    </div>
  <% else %>
    <div class="divide-y divide-slate-50">
      <% @leave_requests.each do |leave| %>
        <div class="px-6 py-4 flex items-start justify-between gap-4 hover:bg-slate-50/50 transition-colors group">
          <div class="flex items-start gap-4 flex-1 min-w-0">
            <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center mt-0.5
              <%= leave.leave_type == 'annual' ? 'bg-brand-50 text-brand-500' :
                  leave.leave_type == 'sick'   ? 'bg-emerald-50 text-emerald-500' :
                  leave.leave_type == 'casual' ? 'bg-amber-50 text-amber-500' :
                                                 'bg-slate-50 text-slate-400' %>">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-0.5">
                <p class="font-bold text-slate-800 capitalize"><%= leave.leave_type %> Leave</p>
                <%= render "shared/leave_badge", status: leave.status %>
              </div>
              <p class="text-sm text-slate-500">
                <%= leave.start_date.strftime("%b %-d, %Y") %>
                <span class="text-slate-300 mx-1">→</span>
                <%= leave.end_date.strftime("%b %-d, %Y") %>
                <span class="text-slate-300 mx-1">·</span>
                <strong class="text-slate-600"><%= leave.duration_days %> day<%= "s" if leave.duration_days > 1 %></strong>
              </p>
              <p class="text-xs text-slate-400 mt-1 truncate max-w-md"><%= leave.reason %></p>
            </div>
          </div>

          <div class="flex items-center gap-2 flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
            <%= link_to leave_request_path(leave),
                  class: "text-xs font-semibold text-slate-500 hover:text-brand-500 border border-slate-200 hover:border-brand-300 px-3 py-1.5 rounded-xl transition-colors" do %>
              View
            <% end %>
            <% if leave.can_cancel? %>
              <%= button_to cancel_leave_request_path(leave), method: :patch,
                    class: "text-xs font-semibold text-red-400 hover:text-red-600 border border-red-100 hover:border-red-300 px-3 py-1.5 rounded-xl transition-colors",
                    data: { turbo_confirm: "Cancel this leave request?" } do %>
                Cancel
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>