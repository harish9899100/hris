<%
  cfg = case status
  when "present"  then ["bg-emerald-100 text-emerald-700", "Present"]
  when "absent"   then ["bg-red-100 text-red-600",         "Absent"]
  when "late"     then ["bg-amber-100 text-amber-700",     "Late"]
  when "half_day" then ["bg-slate-100 text-slate-500",     "Half Day"]
  else                 ["bg-slate-100 text-slate-500",     status&.humanize || "—"]
  end
%>
<span class="inline-flex items-center px-2.5 py-1 rounded-xl text-xs font-bold <%= cfg[0] %>">
  <%= cfg[1] %>
</span>