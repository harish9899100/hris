<h1>My Profile</h1>

<div>
  <p><strong>Employee ID:</strong> <%= @employee.employee_id %></p>
  <p><strong>Name:</strong> <%= @employee.first_name %> <%= @employee.last_name %></p>
  <p><strong>Email:</strong> <%= @employee.email %></p>
  <p><strong>Phone:</strong> <%= @employee.phone %></p>

  <p><strong>Department:</strong> <%= @employee.department&.name %></p>
  <p><strong>Position:</strong> <%= @employee.position&.title %></p>
  <p><strong>Manager:</strong> <%= @employee.manager&.first_name %></p>

  <p><strong>Status:</strong> <%= @employee.employment_status %></p>
  <p><strong>Date of Joining:</strong> <%= @employee.date_of_joining %></p>

</div>

<br>

<% if policy(@employee).update? %>
  <%= link_to "Edit Profile", edit_employee_path(@employee) %>
<% end %>