<div class="max-w-7xl mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Employees</h1>
    <%= link_to "Add Employee", new_employee_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg shadow hover:bg-blue-700" %>
  </div>

  <div class="bg-white p-4 rounded-xl shadow mb-6">
    <%= form_with url: employees_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-4 gap-4" do %>

      <%= text_field_tag :q, params[:q], placeholder: "Search employee...", class: "border rounded-lg px-3 py-2 w-full" %>

      <%= select_tag :department_id,
            options_from_collection_for_select(@departments, :id, :name, params[:department_id]),
            include_blank: "All Departments",
            class: "border rounded-lg px-3 py-2 w-full" %>

      <%= select_tag :status,
            options_for_select(Employee.employment_statuses.keys.map { |s| [s.titleize, s] }, params[:status]),
            include_blank: "All Status",
            class: "border rounded-lg px-3 py-2 w-full" %>

      <%= submit_tag "Filter", class: "bg-gray-800 text-white rounded-lg px-4 py-2 hover:bg-gray-900" %>

    <% end %>
  </div>

  <div class="bg-white rounded-xl shadow overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-100 text-gray-700">
        <tr>
          <th class="px-4 py-3 text-left">Name</th>
          <th class="px-4 py-3">Department</th>
          <th class="px-4 py-3">Position</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3">Actions</th>
        </tr>
      </thead>

      <tbody>
        <% @employees.each do |emp| %>
          <tr class="border-t hover:bg-gray-50">
            <td class="px-4 py-3 font-medium">
              <%= link_to emp.full_name, emp, class: "text-blue-600 hover:underline" %>
            </td>

            <td class="px-4 py-3"><%= emp.department&.name %></td>
            <td class="px-4 py-3"><%= emp.position&.title %></td>

            <td class="px-4 py-3">
              <span class="px-2 py-1 rounded-full text-xs
                <%= emp.active? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                <%= emp.employment_status.titleize %>
              </span>
            </td>

            <td class="px-4 py-3 space-x-2">
              <%= link_to "View", emp, class: "text-blue-600 hover:underline" %>
              <%= link_to "new", new_employee_path %>
              <%= link_to "Attendance Records", attendance_records_path %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="mt-6">
    <%= paginate @employees %>
  </div>
</div>