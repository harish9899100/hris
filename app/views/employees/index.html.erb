<% content_for :title, "Employees" %>
<% content_for :breadcrumbs do %>
  <span class="breadcrumb-item">Employees</span>
<% end %>

<div class="page-header">
  <div>
    <h1 class="page-title">Employees</h1>
    <p class="page-subtitle"><%= @employees.total_count %> total employees</p>
  </div>
  <div class="page-actions">
    <% if policy(Employee).create? %>
      <%= link_to new_employee_path, class: "btn btn-primary" do %>
        + New Employee
      <% end %>
    <% end %>
  </div>
</div>

<div class="filter-bar">
  <%= form_tag employees_path, method: :get, class: "filter-form" do %>
    
    <div class="filter-group">
      <%= text_field_tag :q, params[:q], placeholder: "Search name or email…",
            class: "form-control form-control--sm" %>
    </div>

    <div class="filter-group">
      <%= select_tag :department_id,
            options_from_collection_for_select(@departments, :id, :name, params[:department_id]),
            include_blank: "All Departments",
            class: "form-select form-select--sm" %>
    </div>

    <div class="filter-group">
      <%= select_tag :employment_status,
            options_for_select([
              ["All Status", ""],
              ["Active", "active"],
              ["On Leave", "on_leave"],
              ["Terminated", "terminated"]
            ], params[:employment_status]),
            class: "form-select form-select--sm" %>
    </div>

    <%= submit_tag "Filter", class: "btn btn-outline btn-sm" %>

    <% if params[:q].present? || params[:department_id].present? || params[:employment_status].present? %>
      <%= link_to "Clear", employees_path, class: "btn btn-ghost btn-sm" %>
    <% end %>

  <% end %>
</div>

<div class="card">
  <div class="card-body p-0">
    <% if @employees.any? %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Employee</th>
            <th>Department</th>
            <th>Position</th>
            <th>Date of Joining</th>
            <th>Status</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @employees.each do |employee| %>
            <tr>
              <td>
                <%= link_to employee_path(employee), class: "employee-cell" do %>
                  <div class="avatar-sm">
                    <%= employee.first_name&.first %><%= employee.last_name&.first %>
                  </div>
                  <div>
                    <div class="employee-name">
                      <%= employee.full_name %>
                    </div>
                    <div class="employee-email text-muted">
                      <%= employee.email %>
                    </div>
                  </div>
                <% end %>
              </td>

              <td><%= employee.department&.name || "—" %></td>
              <td><%= employee.position&.title || "—" %></td>

              <td>
                <%= employee.date_of_joining&.strftime("%b %-d, %Y") || "—" %>
              </td>

              <td><%= employee.employment_status %></td>

              <td class="action-btns">
                <%= link_to "View", employee_path(employee), class: "btn btn-xs btn-outline" %>

                <% if policy(employee).update? %>
                  <%= link_to "Edit", edit_employee_path(employee), class: "btn btn-xs btn-ghost" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <div class="pagination-wrap">
        <%= paginate @employees %>
      </div>
    <% else %>
      <div class="empty-state">
        <div class="empty-icon"></div>
        <h3>No employees found</h3>
        <p>Try adjusting your filters or add a new employee.</p>

        <% if policy(Employee).create? %>
          <%= link_to "Add Employee", new_employee_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>